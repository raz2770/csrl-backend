PORT=5000
JWT_SECRET=change-me-in-production

# Firestore: REST transport avoids gRPC issues on some hosts (Render, etc.). Set to "false" to force gRPC.
# Defaults to true via bootstrap-env.js if unset.
FIRESTORE_PREFER_REST=

# Cache full Firestore reads in node-cache for this many ms (default 90000 = 90s). Reduces read quota; set 0 to disable.
# After any write, the cache key is deleted so the next request reloads from Firestore.
FIRESTORE_READ_CACHE_TTL_MS=

# Firebase Admin — enable Firestore persistence for profiles/tests.
# Create a service account in Firebase Console → Project settings → Service accounts.
# Option A: path to the downloaded JSON key file:
GOOGLE_APPLICATION_CREDENTIALS=

# Option A2 (recommended for Render): base64 of service account JSON file contents
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option B: entire JSON as a single line (e.g. for cloud hosts):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
